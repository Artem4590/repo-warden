{
  "name": "repo-warden",
  "version": "0.1.0",
  "private": true,
  "description": "Event-driven GitHub webhook bridge for OpenClaw-powered repository maintenance.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@octokit/webhooks": "^14.1.2",
    "fastify": "^5.6.1",
    "pino-pretty": "^13.1.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^4.0.0"
  }
}
